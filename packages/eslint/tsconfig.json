{
	"include": ["__tests__/**/*.ts", "eslint.config.js"],
	"compilerOptions": {
		/* Type Checking */

		/* Modules */
		"module": "node18",
		"moduleResolution": "node16",
		"rewriteRelativeImportExtensions": true,
		"types": ["node"],

		/* Emit */
		"noEmit": true,

		/* JavaScript Support */
		"allowJs": true,
		"checkJs": true,

		/* Interop Constraints */
		"esModuleInterop": true
	}
}
